# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gridwar
POSTGRES_USER=gridwar
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────
SERVER_PORT=8080
GRID_SIZE=50
CAPTURE_COOLDOWN_MS=3000

# ── Security ──────────────────────────────────────────────────────────────
# In dev, this can be simple. In prod, use a random 32+ char string.
SESSION_SECRET=gridwar-secret-key-1234567890-abcdef

# ── CORS ──────────────────────────────────────────────────────────────────
# In Docker, the frontend runs on port 80.
# In dev (npm run dev), it runs on port 5173.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ── Spring ────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
