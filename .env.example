# GridWar — Environment Variables
# Copy to .env and fill in real values before running docker compose.
# Backend reads these via ${VAR} substitution in application.yml.

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gridwar
POSTGRES_USER=gridwar
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────
SERVER_PORT=8080
GRID_SIZE=50
CAPTURE_COOLDOWN_MS=3000

# ── Security ──────────────────────────────────────────────────────────────
# Must be at least 32 random characters in production
SESSION_SECRET=change-me-to-a-random-32-char-string-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────
# In dev: http://localhost:5173 | In prod: your actual domain
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ── Spring ────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
